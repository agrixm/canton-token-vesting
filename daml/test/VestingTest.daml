module Test.VestingTest where

import Daml.Script
import DA.Date as D
import DA.Time as T
import DA.Assert
import Vesting

-- === Test Setup ===

-- | A helper to create a standard vesting setup for tests.
setupVesting : Script (Party, Party, VestingSchedule, ContractId VestingProposal)
setupVesting = do
  issuer <- allocateParty "Issuer"
  beneficiary <- allocateParty "Beneficiary"

  let
    today = D.date 2024 Jan 1
    schedule = VestingSchedule with
      grantId = "grant-123"
      tokenIdentifier = "ACME"
      totalAmount = 10000.0
      startDate = today
      cliffDate = D.addDays today 365        -- 1 year cliff
      endDate = D.addDays today (365 * 4)  -- 4 year total vesting period

  proposalCid <- submit issuer do
    createCmd VestingProposal with issuer, beneficiary, schedule

  return (issuer, beneficiary, schedule, proposalCid)

-- === Test Cases ===

-- | Test the successful creation of a proposal and its acceptance by the beneficiary.
proposalAcceptanceTest : Script ()
proposalAcceptanceTest = script do
  p "proposalAcceptanceTest: Testing proposal creation and acceptance"
  (issuer, beneficiary, schedule, proposalCid) <- setupVesting

  -- Beneficiary accepts the proposal
  agreementCid <- submit beneficiary do
    exerciseCmd proposalCid Accept

  -- Verify the VestingAgreement contract is created correctly
  agreement <- fetch agreementCid
  assertEqual agreement.issuer issuer
  assertEqual agreement.beneficiary beneficiary
  assertEqual agreement.schedule schedule
  assertEqual agreement.claimedAmount 0.0

  -- Verify the proposal is archived after acceptance
  (proposals, _) <- query @VestingProposal beneficiary
  assertEqual (length proposals) 0
  p "  ✅ Success: Agreement created and proposal archived."

-- | Test that attempting to claim tokens before the cliff date fails.
claimBeforeCliffFailsTest : Script ()
claimBeforeCliffFailsTest = script do
  p "claimBeforeCliffFailsTest: Testing that claims before the cliff date fail"
  (issuer, beneficiary, schedule, proposalCid) <- setupVesting
  agreementCid <- submit beneficiary do exerciseCmd proposalCid Accept

  -- Set time to 6 months after start date (before 1-year cliff)
  let preCliffTime = T.time (D.addDays schedule.startDate 180) 0 0 0
  
  -- Attempting to claim should fail
  submitMustFail beneficiary do
    exerciseCmd agreementCid Claim with claimTime = preCliffTime
  
  p "  ✅ Success: Claim correctly failed before cliff."

-- | Test a successful token claim after the cliff and halfway through the vesting period.
claimAfterCliffSucceedsTest : Script ()
claimAfterCliffSucceedsTest = script do
  p "claimAfterCliffSucceedsTest: Testing a successful claim after the cliff"
  (issuer, beneficiary, schedule, proposalCid) <- setupVesting
  agreementCid <- submit beneficiary do exerciseCmd proposalCid Accept

  -- Set time to 2 years in (50% vested)
  let twoYearsIn = D.addDays schedule.startDate (365 * 2)
  let claimTime = T.time twoYearsIn 12 0 0

  -- The expected amount vested after 2 of 4 years is 50%.
  let expectedVested = schedule.totalAmount / 2.0

  -- Beneficiary claims vested tokens
  (newEventCid, newAgreementCid) <- submit beneficiary do
    exerciseCmd agreementCid Claim with claimTime

  -- Verify the ClaimedEvent
  claimedEvent <- fetch newEventCid
  assertEqual claimedEvent.beneficiary beneficiary
  assert (abs (claimedEvent.amountClaimed - expectedVested) < 0.0001)

  -- Verify the new state of the VestingAgreement
  newAgreement <- fetch newAgreementCid
  assert (abs (newAgreement.claimedAmount - expectedVested) < 0.0001)

  p "  ✅ Success: Claim processed and contract state updated correctly."

-- | Test a scenario with multiple claims over the vesting period.
multipleClaimsTest : Script ()
multipleClaimsTest = script do
  p "multipleClaimsTest: Testing multiple claims over time"
  (issuer, beneficiary, schedule, proposalCid) <- setupVesting
  initialAgreementCid <- submit beneficiary do exerciseCmd proposalCid Accept

  -- Claim 1: Just after the 1-year cliff (25% vested)
  let claimTime1 = T.time schedule.cliffDate 1 0 0
  let expectedVested1 = schedule.totalAmount * 0.25

  (event1Cid, agreementCid1) <- submit beneficiary do
    exerciseCmd initialAgreementCid Claim with claimTime = claimTime1

  event1 <- fetch event1Cid
  assert (abs (event1.amountClaimed - expectedVested1) < 0.0001)
  agreement1 <- fetch agreementCid1
  assert (abs (agreement1.claimedAmount - expectedVested1) < 0.0001)
  p "  - First claim at cliff successful."

  -- Claim 2: At 3 years in (75% total vested)
  let claimTime2 = T.time (D.addDays schedule.startDate (365 * 3)) 1 0 0
  let totalVested2 = schedule.totalAmount * 0.75
  let expectedClaimAmount2 = totalVested2 - expectedVested1

  (event2Cid, agreementCid2) <- submit beneficiary do
    exerciseCmd agreementCid1 Claim with claimTime = claimTime2

  event2 <- fetch event2Cid
  assert (abs (event2.amountClaimed - expectedClaimAmount2) < 0.0001)
  agreement2 <- fetch agreementCid2
  assert (abs (agreement2.claimedAmount - totalVested2) < 0.0001)
  p "  - Second claim at year 3 successful."
  p "  ✅ Success: Multiple claims handled correctly."

-- | Test that the issuer can revoke the agreement, forfeiting unvested tokens.
revocationTest : Script ()
revocationTest = script do
  p "revocationTest: Testing the issuer's ability to revoke the agreement"
  (issuer, beneficiary, schedule, proposalCid) <- setupVesting
  agreementCid <- submit beneficiary do exerciseCmd proposalCid Accept

  -- Set time to halfway through vesting period (2 years)
  let revokeTime = T.time (D.addDays schedule.startDate (365 * 2)) 0 0 0

  -- Issuer revokes the agreement
  revokedEventCid <- submit issuer do
    exerciseCmd agreementCid Revoke with revokeTime

  -- Verify the RevokedEvent details
  revokedEvent <- fetch revokedEventCid
  let expectedVested = schedule.totalAmount / 2.0
  let expectedForfeited = schedule.totalAmount - expectedVested
  assert (abs (revokedEvent.vestedAmountAtRevocation - expectedVested) < 0.0001)
  assert (abs (revokedEvent.unvestedAmountForfeited - expectedForfeited) < 0.0001)

  -- Verify the original agreement is archived
  (agreements, _) <- query @VestingAgreement beneficiary
  assertEqual (length agreements) 0

  -- Verify beneficiary can no longer act on the (now archived) contract
  submitMustFail beneficiary do
    exerciseCmd agreementCid Claim with claimTime = revokeTime

  p "  ✅ Success: Agreement revoked and archived."

-- | Test that the issuer can accelerate the vesting schedule.
accelerationTest : Script ()
accelerationTest = script do
  p "accelerationTest: Testing vesting acceleration by the issuer"
  (issuer, beneficiary, schedule, proposalCid) <- setupVesting
  agreementCid <- submit beneficiary do exerciseCmd proposalCid Accept

  -- Set time to 1.5 years into the schedule
  let accelerationDate = D.addDays schedule.startDate (365 + 182)
  let accelerationTime = T.time accelerationDate 0 0 0

  -- Issuer accelerates vesting, making the current date the new end date
  newAgreementCid <- submit issuer do
    exerciseCmd agreementCid Accelerate with newEndDate = accelerationDate

  -- Verify the new agreement has the updated schedule
  newAgreement <- fetch newAgreementCid
  assertEqual newAgreement.schedule.endDate accelerationDate

  -- Beneficiary should now be able to claim the full amount
  (eventCid, finalAgreementCid) <- submit beneficiary do
    exerciseCmd newAgreementCid Claim with claimTime = accelerationTime

  -- The claim should be for the entire total amount since vesting is complete
  event <- fetch eventCid
  assert (abs (event.amountClaimed - schedule.totalAmount) < 0.0001)
  
  finalAgreement <- fetch finalAgreementCid
  assert (abs (finalAgreement.claimedAmount - schedule.totalAmount) < 0.0001)
  p "  - Acceleration successful, full amount claimed."

  -- A subsequent claim should yield 0 new tokens
  (event2Cid, _) <- submit beneficiary do
    exerciseCmd finalAgreementCid Claim with claimTime = T.addRelTime accelerationTime (T.minutes 1)

  event2 <- fetch event2Cid
  assertEqual event2.amountClaimed 0.0
  p "  - Subsequent claim after full vesting correctly yields zero."
  p "  ✅ Success: Acceleration logic is correct."

-- | Main test suite that runs all vesting-related tests.
vestingTests : Script ()
vestingTests = script do
  proposalAcceptanceTest
  claimBeforeCliffFailsTest
  claimAfterCliffSucceedsTest
  multipleClaimsTest
  revocationTest
  accelerationTest